# Kconfig.defconfig for sofle shield
# This file helps define default Kconfig symbols for the sofle shield.

# Ensure display status and activity are defined and enabled
config ZMK_DISPLAY_STATUS
    default y

config ZMK_ACTIVITY
    default y

# Define the log levels for display and activity
config ZMK_DISPLAY_LOG_LEVEL_DBG
    default y

config ZMK_ACTIVITY_LOG_LEVEL_DBG
    default y

# Add other display related Kconfig options here if they become undefined
# config DISPLAY_BUFFER_SIZE
#     default 512
